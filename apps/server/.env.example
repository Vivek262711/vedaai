# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://vedaai:vedaai_secret@localhost:27017/vedaai?authSource=admin

# Redis
REDIS_URL=redis://localhost:6379

# AI
OPENAI_API_KEY=sk-your-key-here
AI_PROVIDER=openai
AI_MODEL=gpt-4o

# Queue
QUEUE_CONCURRENCY=3
JOB_TIMEOUT=120000
JOB_MAX_RETRIES=3

# PDF
PDF_STORAGE_PATH=./storage/pdfs
