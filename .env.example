# ── MongoDB ──
MONGO_USER=vedaai
MONGO_PASS=vedaai_secret
MONGO_URI=mongodb://vedaai:vedaai_secret@localhost:27017/vedaai?authSource=admin

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── AI Provider ──
OPENAI_API_KEY=sk-your-key-here
AI_PROVIDER=openai
AI_MODEL=gpt-4o

# ── Server ──
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=http://localhost:4000
